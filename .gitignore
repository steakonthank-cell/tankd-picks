fanduel_cache/
pickfinder_cache/
moneylines_cache/
data/espn_odds_cache.json

# ── Scanner output (regenerated at runtime) ───────────────────────────────────
output/

# ── Raw data (too large) ──────────────────────────────────────────────────────
data/tennis/raw/
data/nba/raw/
data/mlb/raw/
data/wnba/raw/

# ── NBA training data (464MB — too large for GitHub) ─────────────────────────
data/nba/processed/

# ── Model files — committed so Streamlit Cloud can run AI scanners ────────────
# (all individual files are <5MB, total ~178MB)

# ── Large tennis training CSV (1.5GB) — player_cache.parquet is used instead ─
data/tennis/processed/training_dataset.csv

